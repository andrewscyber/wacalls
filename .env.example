# Variáveis de ambiente para o WaCalls — Clickmixhub

# ─────────────────────────────────────────────────────────────
# SEGURANÇA
# ─────────────────────────────────────────────────────────────

# Token de autenticação Bearer para proteger a API.
# Deixe vazio para desativar autenticação (não recomendado em produção).
# Gere um token seguro com: openssl rand -hex 32
WACALLS_TOKEN=

# ─────────────────────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────────────────────

# Endereço de escuta do servidor HTTP
# WACALLS_ADDR=:8080

# Caminho para o banco SQLite (sessões WhatsApp)
# WACALLS_DB=/app/data/wacalls.db

# Diretório dos assets estáticos do cliente React
# WACALLS_STATIC=client/dist

# Máximo de chamadas simultâneas por sessão (0 = ilimitado)
# WACALLS_MAX_CALLS=8
